# CloudShift Backend Environment Variables
# Copy this to .env and fill in your values

# ─────────────────────────────────────────────────────────────────────────────
# SECURITY: NEVER use long-lived IAM user access keys in production.
#
# RECOMMENDED: Use short-lived credentials via AWS SSO / IAM Identity Center:
#   1. aws sso configure       → set up your SSO profile
#   2. aws sso login           → browser-based MFA login
#   3. aws sts get-caller-identity → verify you have valid session
#
# MFA ENFORCEMENT (IAM policy to add to your IAM user / group):
#   {
#     "Effect": "Deny",
#     "Action": "*",
#     "Resource": "*",
#     "Condition": {
#       "BoolIfExists": { "aws:MultiFactorAuthPresent": "false" }
#     }
#   }
#
# KEY ROTATION: Rotate access keys every 30 days. Delete unused keys immediately.
# ─────────────────────────────────────────────────────────────────────────────

# For local dev ONLY — prefer `aws sso login` + profiles instead of hardcoded keys
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=us-east-1

# Set after running: cdk deploy
DMS_TASK_ARN=arn:aws:dms:us-east-1:ACCOUNT:task:XXXXX
DYNAMODB_TABLE=cloudshift-sessions
S3_BUCKET=cloudshift-configs-ACCOUNT-us-east-1

# ─────────────────────────────────────────────────────────────────────────────
# SECURITY: CORS — set this to your deployed frontend URL.
# Lambda and API Gateway use this to restrict cross-origin access.
# Example: https://cloudshift.example.com
# Never set to * in production.
# ─────────────────────────────────────────────────────────────────────────────
ALLOWED_ORIGIN=http://localhost:5173

# Optional: Anthropic Claude API for enhanced assessments
# ANTHROPIC_API_KEY=sk-ant-...

# Local dev server port
PORT=4000
