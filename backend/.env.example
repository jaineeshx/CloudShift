# CloudShift Backend Environment Variables
# Copy this to .env and fill in your values

AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=us-east-1

# Set after running: cdk deploy
DMS_TASK_ARN=arn:aws:dms:us-east-1:ACCOUNT:task:XXXXX
DYNAMODB_TABLE=cloudshift-sessions
S3_BUCKET=cloudshift-configs-ACCOUNT-us-east-1

# Optional: Anthropic Claude API for enhanced assessments
# ANTHROPIC_API_KEY=sk-ant-...

# Local dev server port
PORT=4000
